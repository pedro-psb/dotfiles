{
  "permissions": {
    "allow": [
      "Bash(oci-env *)",
      "Bash(acli jira workitem search *)",
      "Bash(acli jira workitem view *)",
      "Bash(acli jira workitem list *)",
      "Bash(acli jira project list *)",
      "Bash(acli jira board list *)",
      "Bash(acli jira sprint list *)",
      "Bash(gh search *)",
      "Bash(gh pr list *)",
      "Bash(gh pr view *)",
      "Bash(gh pr status *)",
      "Bash(gh issue list *)",
      "Bash(gh issue view *)",
      "Bash(gh repo view *)",
      "Bash(gh repo list *)",
      "Bash(gh run list *)",
      "Bash(gh run view *)",
      "Bash(gh release list *)",
      "Bash(gh release view *)",
      "Bash(find * -exec grep *)"
    ]
  },
  "model": "claude-sonnet-4-6",
  "hooks": {
    "Notification": [
      {
        "matcher": "permission_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "notify-send 'Claude needs permission' $PWD"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "atlassian@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "clangd-lsp@claude-plugins-official": true,
    "ast-grep@ast-grep-marketplace": true
  },
  "extraKnownMarketplaces": {
    "ast-grep-marketplace": {
      "source": {
        "source": "github",
        "repo": "ast-grep/agent-skill"
      }
    }
  }
}
